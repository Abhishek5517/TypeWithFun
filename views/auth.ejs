<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TypeFun – <%= page === 'login' ? 'Sign In' : 'Join' %></title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0f;
  --surface: #12121a;
  --card: #1a1a26;
  --border: #2a2a3d;
  --accent: #6d28d9;
  --accent2: #7c3aed;
  --glow: rgba(109,40,217,0.3);
  --text: #e8e8f0;
  --muted: #6b6b8a;
  --green: #10b981;
  --red: #ef4444;
  --mono: 'Space Mono', monospace;
  --sans: 'DM Sans', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--sans)}
body{display:flex;align-items:center;justify-content:center;min-height:100vh;overflow:hidden}
.bg-grid{position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:48px 48px;opacity:0.3;z-index:0}
.bg-orb{position:fixed;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(109,40,217,0.15),transparent 70%);z-index:0}
.bg-orb.a{top:-100px;left:-100px}
.bg-orb.b{bottom:-100px;right:-100px;background:radial-gradient(circle,rgba(16,185,129,0.1),transparent 70%)}
.card{position:relative;z-index:1;width:100%;max-width:440px;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:40px;box-shadow:0 0 60px rgba(109,40,217,0.15)}
.logo{text-align:center;margin-bottom:32px}
.logo-mark{display:inline-flex;align-items:center;gap:10px}
.logo-icon{width:44px;height:44px;border-radius:12px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:18px;color:#fff;box-shadow:0 0 20px var(--glow)}
.logo-text{font-family:var(--mono);font-size:22px;font-weight:700;letter-spacing:-1px}
.logo-text span{color:var(--accent2)}
.tabs{display:flex;background:var(--surface);border-radius:12px;padding:4px;margin-bottom:28px;border:1px solid var(--border)}
.tab{flex:1;text-align:center;padding:10px;border-radius:9px;font-size:14px;font-weight:500;cursor:pointer;transition:.2s;color:var(--muted);text-decoration:none}
.tab.active{background:var(--accent);color:#fff;box-shadow:0 0 20px var(--glow)}
.error-box{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:12px 16px;font-size:13px;color:#fca5a5;margin-bottom:20px}
.form-group{margin-bottom:18px}
label{display:block;font-size:12px;font-weight:600;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;margin-bottom:8px}
input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-size:15px;font-family:var(--sans);transition:.2s;outline:none}
input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow)}
input::placeholder{color:var(--muted)}
.btn-primary{width:100%;background:var(--accent);color:#fff;border:none;border-radius:10px;padding:14px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--sans);transition:.2s;box-shadow:0 0 20px var(--glow);margin-top:8px}
.btn-primary:hover{background:var(--accent2);transform:translateY(-1px);box-shadow:0 0 30px var(--glow)}
.divider{text-align:center;color:var(--muted);font-size:13px;margin:20px 0;position:relative}
.divider::before,.divider::after{content:'';position:absolute;top:50%;width:40%;height:1px;background:var(--border)}
.divider::before{left:0}.divider::after{right:0}
.hint{text-align:center;font-size:13px;color:var(--muted);margin-top:20px}
.hint a{color:var(--accent2);text-decoration:none;font-weight:500}
.hint a:hover{text-decoration:underline}
.keyboard-art{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);opacity:0.15;font-family:var(--mono);font-size:11px;color:var(--text);white-space:nowrap;z-index:0}
</style>
</head>
<body>
<div class="bg-grid"></div>
<div class="bg-orb a"></div>
<div class="bg-orb b"></div>
<div class="card">
  <div class="logo">
    <div class="logo-mark">
      <div class="logo-icon">TF</div>
      <div class="logo-text">Type<span>Fun</span></div>
    </div>
  </div>
  <div class="tabs">
    <a href="/login" class="tab <%= page === 'login' ? 'active' : '' %>">Sign In</a>
    <a href="/register" class="tab <%= page === 'register' ? 'active' : '' %>">Register</a>
  </div>
  <% if (error) { %>
  <div class="error-box">⚠ <%= error %></div>
  <% } %>
  <% if (page === 'login') { %>
  <form method="POST" action="/login">
    <div class="form-group">
      <label>Username</label>
      <input type="text" name="username" placeholder="your_username" required autofocus>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required>
    </div>
    <button type="submit" class="btn-primary">→ Sign In</button>
  </form>
  <div class="hint">Don't have an account? <a href="/register">Register free</a></div>
  <% } else { %>
  <form method="POST" action="/register">
    <div class="form-group">
      <label>Username</label>
      <input type="text" name="username" placeholder="choose_a_name" minlength="3" maxlength="30" required autofocus>
    </div>
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" placeholder="you@email.com" required>
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="min 6 characters" minlength="6" required>
    </div>
    <button type="submit" class="btn-primary">→ Create Account</button>
  </form>
  <div class="hint">Already have an account? <a href="/login">Sign in</a></div>
  <% } %>
</div>
<div class="keyboard-art">[ Q ][ W ][ E ][ R ][ T ][ Y ][ U ][ I ][ O ][ P ] &nbsp;&nbsp; [ A ][ S ][ D ][ F ][ G ][ H ][ J ][ K ][ L ] &nbsp;&nbsp; [ Z ][ X ][ C ][ V ][ B ][ N ][ M ]</div>
</body>
</html>
