<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TypeFun – Play</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{
  --bg:#0a0a0f;--surface:#12121a;--card:#1a1a26;--card2:#1e1e2e;
  --border:#2a2a3d;--border2:#3a3a5c;
  --accent:#6d28d9;--accent2:#7c3aed;--accent3:#8b5cf6;
  --glow:rgba(109,40,217,0.25);
  --green:#10b981;--green-g:rgba(16,185,129,0.2);
  --amber:#f59e0b;--red:#ef4444;--blue:#3b82f6;
  --text:#e8e8f0;--text2:#a0a0c0;--muted:#5a5a7a;
  --mono:'Space Mono',monospace;--sans:'DM Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh}
.bg-grid{position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:48px 48px;opacity:0.2;z-index:0;pointer-events:none}

nav{position:sticky;top:0;z-index:100;background:rgba(10,10,15,0.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 24px}
.nav-inner{max-width:1200px;margin:0 auto;height:60px;display:flex;align-items:center;gap:12px}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-icon{width:36px;height:36px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:14px;color:#fff;box-shadow:0 0 16px var(--glow);flex-shrink:0}
.logo-text{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--text)}
.logo-text span{color:var(--accent3)}
.nav-links{display:flex;gap:4px;margin-left:auto}
.nav-link{padding:7px 14px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text2);text-decoration:none;transition:.2s;border:1px solid transparent}
.nav-link:hover{color:var(--text);background:var(--card);border-color:var(--border)}
.nav-link.active{color:var(--accent3);background:rgba(109,40,217,0.12);border-color:rgba(109,40,217,0.3)}
.user-chip{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);border-radius:99px;padding:5px 14px 5px 5px;margin-left:8px}
.avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.user-name{font-size:13px;font-weight:500;color:var(--text)}

.page{max-width:1200px;margin:0 auto;padding:24px;position:relative;z-index:1}
.section-title{font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:16px}

.mode-tabs{display:flex;background:var(--surface);border-radius:14px;padding:5px;border:1px solid var(--border);margin-bottom:24px;width:fit-content}
.mode-tab{padding:9px 20px;border-radius:10px;font-size:14px;font-weight:500;cursor:pointer;transition:.2s;color:var(--text2);border:1px solid transparent}
.mode-tab.active{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 0 20px var(--glow)}

.solo-panel,.multi-panel{display:none}
.solo-panel.show,.multi-panel.show{display:block}

.controls-row{display:flex;align-items:center;gap:10px;margin-bottom:20px;flex-wrap:wrap}
.ctrl-group{display:flex;background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden}
.ctrl-btn{padding:8px 16px;font-size:13px;font-weight:500;cursor:pointer;background:transparent;color:var(--text2);border:none;border-right:1px solid var(--border);transition:.15s;font-family:var(--sans)}
.ctrl-btn:last-child{border-right:none}
.ctrl-btn:hover{color:var(--text);background:var(--card)}
.ctrl-btn.active{background:var(--accent);color:#fff}
#race-settings .ctrl-btn{flex:1;text-align:center}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px}
.stat-box{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 16px;position:relative;overflow:hidden}
.stat-box::before{content:'';position:absolute;inset:0;opacity:0;transition:.3s}
.stat-box.wpm-box::before{background:linear-gradient(135deg,rgba(109,40,217,0.1),transparent)}
.stat-box.acc-box::before{background:linear-gradient(135deg,rgba(16,185,129,0.1),transparent)}
.stat-box.time-box::before{background:linear-gradient(135deg,rgba(239,68,68,0.1),transparent)}
.stat-box.keys-box::before{background:linear-gradient(135deg,rgba(245,158,11,0.1),transparent)}
.stat-box.active-stat::before{opacity:1}
.stat-lbl{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px}
.stat-val{font-family:var(--mono);font-size:32px;font-weight:700;line-height:1}
.stat-val.wpm{color:var(--accent3)}
.stat-val.acc{color:var(--green)}
.stat-val.timer{color:var(--red)}
.stat-val.keys{color:var(--amber)}
.stat-unit{font-size:11px;color:var(--muted);margin-top:3px}

.prog-bar{height:3px;background:var(--surface);border-radius:99px;margin-bottom:20px;overflow:hidden;border:1px solid var(--border)}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent3));border-radius:99px;width:0%;transition:width .15s ease}

.type-box{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px;cursor:text;transition:.2s;position:relative}
.type-box:hover{border-color:var(--border2)}
.type-box.focused{border-color:rgba(109,40,217,0.5);box-shadow:0 0 0 3px var(--glow)}

/* Solo text display */
#text-display{font-family:var(--mono);font-size:20px;line-height:2;letter-spacing:.3px;user-select:none;min-height:120px;margin-bottom:16px;word-break:break-word}
#text-display span.correct{color:var(--green)}
#text-display span.wrong{color:var(--red);text-decoration:underline;text-underline-offset:4px}
#text-display span.current{border-left:2px solid var(--accent3);margin-left:-1px;color:var(--text);animation:caretBlink .8s ease infinite}
#text-display span.pending{color:var(--muted)}

/* Race text display — same styling as solo */
#race-text-display{font-family:var(--mono);font-size:18px;line-height:2;letter-spacing:.3px;user-select:none;min-height:100px;margin-bottom:12px;word-break:break-word}
#race-text-display span.correct{color:var(--green)}
#race-text-display span.wrong{color:var(--red);text-decoration:underline;text-underline-offset:4px}
#race-text-display span.current{border-left:2px solid var(--accent3);margin-left:-1px;color:var(--text);animation:caretBlink .8s ease infinite}
#race-text-display span.pending{color:var(--muted)}

@keyframes caretBlink{0%,100%{border-left-color:var(--accent3)}50%{border-left-color:transparent}}
#hidden-input{opacity:0;position:absolute;height:0;width:0;pointer-events:none}
.type-hint{font-size:13px;color:var(--muted);border-top:1px solid var(--border);padding-top:12px;display:flex;align-items:center;gap:8px}
.type-hint i{font-size:14px}

.chunk-indicator{font-size:11px;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:6px}
.chunk-dots{display:flex;gap:4px}
.chunk-dot{width:6px;height:6px;border-radius:50%;background:var(--border2);transition:.3s}
.chunk-dot.done{background:var(--green)}
.chunk-dot.active{background:var(--accent3)}

.result-panel{background:var(--card);border:1px solid rgba(109,40,217,0.4);border-radius:16px;padding:28px;margin-top:16px;display:none;text-align:center;box-shadow:0 0 40px var(--glow)}
.result-emoji{font-size:40px;margin-bottom:8px}
.result-title{font-family:var(--mono);font-size:22px;font-weight:700;margin-bottom:4px}
.result-sub{color:var(--text2);font-size:14px;margin-bottom:24px}
.result-stats{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;margin-bottom:24px}
.rs{text-align:center}
.rs-num{font-family:var(--mono);font-size:30px;font-weight:700}
.rs-lbl{font-size:12px;color:var(--muted);margin-top:2px}
.btn-restart{background:var(--accent);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:14px;font-weight:600;cursor:pointer;font-family:var(--sans);transition:.2s;box-shadow:0 0 20px var(--glow)}
.btn-restart:hover{background:var(--accent2);transform:translateY(-1px)}

.multi-layout{display:grid;grid-template-columns:340px 1fr;gap:20px;align-items:start}
.room-sidebar{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:20px}
.race-main{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px}

.room-actions{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.btn-create{background:var(--accent);color:#fff;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:600;cursor:pointer;width:100%;transition:.2s;box-shadow:0 0 16px var(--glow)}
.btn-create:hover{background:var(--accent2)}
.join-form{display:flex;gap:8px}
.join-input{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:11px 14px;color:var(--text);font-size:14px;font-family:var(--mono);letter-spacing:2px;text-transform:uppercase;outline:none}
.join-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--glow)}
.btn-join{background:var(--green);color:#fff;border:none;border-radius:10px;padding:11px 16px;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap}

.room-info{border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:16px;display:none}
.room-code-display{font-family:var(--mono);font-size:28px;font-weight:700;color:var(--accent3);letter-spacing:4px;text-align:center;margin-bottom:4px}
.room-status-badge{display:inline-flex;align-items:center;gap:6px;font-size:12px;padding:4px 12px;border-radius:99px;font-weight:600;margin:0 auto 12px;display:flex;width:fit-content}
.badge-waiting{background:rgba(245,158,11,0.15);color:var(--amber);border:1px solid rgba(245,158,11,0.3)}
.badge-racing{background:rgba(16,185,129,0.15);color:var(--green);border:1px solid rgba(16,185,129,0.3)}
.btn-start{width:100%;background:var(--green);color:#fff;border:none;border-radius:10px;padding:12px;font-size:14px;font-weight:600;cursor:pointer;transition:.2s;display:none}
.btn-start:hover{filter:brightness(1.1)}

.players-list{display:flex;flex-direction:column;gap:8px}
.player-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px}
.p-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.p-name{font-size:13px;font-weight:500;flex:1}
.p-you{font-size:10px;color:var(--accent3);font-weight:600;padding:2px 8px;background:rgba(139,92,246,0.15);border-radius:99px}
.p-wpm{font-family:var(--mono);font-size:13px;color:var(--accent3);min-width:50px;text-align:right}

.race-track-area{margin-bottom:20px}
.race-track{margin-bottom:8px;display:flex;align-items:center;gap:10px}
.track-player{font-size:12px;color:var(--text2);width:90px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.track-bar{flex:1;height:28px;background:var(--surface);border-radius:8px;overflow:hidden;border:1px solid var(--border);position:relative}
.track-fill{height:100%;border-radius:8px;transition:width .3s ease;min-width:4px;position:relative;display:flex;align-items:center;justify-content:flex-end;padding-right:8px}
.track-wpm{font-family:var(--mono);font-size:11px;color:var(--muted);width:60px;text-align:right;flex-shrink:0}

.chat-panel{border:1px solid var(--border);border-radius:12px;margin-top:16px;display:none;overflow:hidden}
.chat-header{font-size:11px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(--muted);padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px}
.chat-messages{height:190px;overflow-y:auto;padding:10px;display:flex;flex-direction:column;gap:5px;scroll-behavior:smooth}
.chat-messages::-webkit-scrollbar{width:4px}.chat-messages::-webkit-scrollbar-track{background:transparent}.chat-messages::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.chat-msg{display:flex;gap:7px;align-items:flex-end}
.chat-msg.mine{flex-direction:row-reverse}
.chat-avatar{width:22px;height:22px;border-radius:50%;font-size:9px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-bottom:2px}
.chat-bubble{background:var(--surface);border:1px solid var(--border);border-radius:10px;border-bottom-left-radius:3px;padding:6px 10px;max-width:82%;word-break:break-word}
.chat-msg.mine .chat-bubble{background:rgba(109,40,217,0.18);border-color:rgba(109,40,217,0.35);border-bottom-left-radius:10px;border-bottom-right-radius:3px}
.chat-name{font-size:10px;color:var(--muted);margin-bottom:2px;font-weight:500}
.chat-text{font-size:13px;color:var(--text);line-height:1.4}
.chat-system-msg{text-align:center;font-size:11px;color:var(--muted);padding:2px 0}
.chat-input-row{display:flex;gap:6px;padding:8px 10px;border-top:1px solid var(--border);background:var(--surface)}
.chat-input{flex:1;background:var(--card);border:1px solid var(--border);border-radius:8px;padding:7px 10px;color:var(--text);font-size:13px;font-family:var(--sans);outline:none;transition:.15s}
.chat-input:focus{border-color:rgba(109,40,217,0.5)}
.chat-send{background:var(--accent);color:#fff;border:none;border-radius:8px;padding:7px 11px;cursor:pointer;font-size:12px;transition:.15s;flex-shrink:0}
.chat-send:hover{background:var(--accent2)}

.race-text-box{display:none;margin-top:16px}
.countdown-overlay{position:absolute;inset:0;background:rgba(10,10,15,0.85);border-radius:16px;display:none;align-items:center;justify-content:center;z-index:10;flex-direction:column;gap:8px}
.countdown-num{font-family:var(--mono);font-size:80px;font-weight:700;color:var(--accent3);text-shadow:0 0 40px var(--glow);animation:pulse .8s ease}
@keyframes pulse{from{transform:scale(1.3);opacity:.5}to{transform:scale(1);opacity:1}}
.countdown-msg{font-size:16px;color:var(--text2)}

.multi-result{background:var(--card);border:1px solid rgba(16,185,129,0.3);border-radius:16px;padding:24px;display:none;margin-top:16px}
.podium{display:flex;align-items:flex-end;justify-content:center;gap:8px;margin-bottom:24px}
.podium-item{text-align:center}
.podium-bar{width:80px;background:var(--surface);border-radius:8px 8px 0 0;display:flex;align-items:center;justify-content:center;font-size:20px}
.podium-name{font-size:13px;font-weight:500;margin-top:8px;max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.podium-wpm{font-family:var(--mono);font-size:14px;color:var(--accent3)}
.podium-1 .podium-bar{height:100px;background:linear-gradient(180deg,rgba(245,158,11,0.3),transparent);border:1px solid var(--amber)}
.podium-2 .podium-bar{height:70px;background:linear-gradient(180deg,rgba(148,163,184,0.2),transparent);border:1px solid #94a3b8}
.podium-3 .podium-bar{height:50px;background:linear-gradient(180deg,rgba(180,83,9,0.2),transparent);border:1px solid #b45309}

.btn-new-race{background:var(--accent);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-size:14px;font-weight:600;cursor:pointer;margin:0 auto;display:block}

.toast{position:fixed;bottom:24px;right:24px;z-index:1000;display:flex;flex-direction:column;gap:8px}
.toast-item{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:12px 16px;font-size:13px;display:flex;align-items:center;gap:10px;animation:slideIn .3s ease;box-shadow:0 8px 24px rgba(0,0,0,0.4)}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
.toast-item.success{border-color:rgba(16,185,129,0.4);color:#6ee7b7}
.toast-item.error{border-color:rgba(239,68,68,0.4);color:#fca5a5}
.toast-item.info{border-color:rgba(109,40,217,0.4);color:var(--accent3)}

@media(max-width:768px){
  .stats-grid{grid-template-columns:repeat(2,1fr)}
  .multi-layout{grid-template-columns:1fr}
  #text-display{font-size:16px}
  #race-text-display{font-size:14px}
}
</style>
</head>
<body>
<div class="bg-grid"></div>
<nav>
  <div class="nav-inner">
    <a href="/play" class="logo">
      <div class="logo-icon">TF</div>
      <div class="logo-text">Type<span>Fun</span></div>
    </a>
    <div class="nav-links">
      <a href="/play" class="nav-link active"><i class="fa-solid fa-keyboard"></i> Play</a>
      <a href="/dashboard" class="nav-link"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
      <a href="/leaderboard" class="nav-link"><i class="fa-solid fa-trophy"></i> Leaderboard</a>
    </div>
    <div class="user-chip" style="margin-left:auto">
      <div class="avatar" style="background:<%= user.avatar_color %>">
        <%= user.username ? user.username.charAt(0).toUpperCase() : '?' %>
      </div>
      <span class="user-name"><%=user.username%></span>
    </div>
    <a href="/logout" class="nav-link" style="margin-left:8px;color:var(--red)"><i class="fa-solid fa-right-from-bracket"></i></a>
  </div>
</nav>

<div class="page">
  <div class="mode-tabs">
    <div class="mode-tab active" onclick="switchMode('solo',this)"><i class="fa-solid fa-user"></i> Solo Practice</div>
    <div class="mode-tab" onclick="switchMode('multi',this)"><i class="fa-solid fa-users"></i> Multiplayer Race</div>
  </div>

  <!-- SOLO PANEL -->
  <div class="solo-panel show" id="solo-panel">
    <div class="controls-row">
      <div>
        <div class="section-title">Time</div>
        <div class="ctrl-group" id="time-ctrl-group">
          <button class="ctrl-btn" onclick="selectTime(15,this)">15s</button>
          <button class="ctrl-btn active" onclick="selectTime(30,this)">30s</button>
          <button class="ctrl-btn" onclick="selectTime(60,this)">60s</button>
          <button class="ctrl-btn" onclick="selectTime(120,this)">120s</button>
        </div>
      </div>
      <div>
        <div class="section-title">Mode</div>
        <div class="ctrl-group" id="mode-ctrl-group">
          <button class="ctrl-btn active" onclick="selectTextMode('normal',this)">Normal</button>
          <button class="ctrl-btn" onclick="selectTextMode('punctuation',this)">@ Punct.</button>
          <button class="ctrl-btn" onclick="selectTextMode('numbers',this)"># Nums</button>
        </div>
      </div>
      <div style="margin-left:auto;align-self:flex-end">
        <button class="ctrl-btn" onclick="resetSolo()" style="border:1px solid var(--border);border-radius:10px;padding:8px 16px;color:var(--text2)"><i class="fa-solid fa-rotate-left"></i> Reset</button>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-box wpm-box"><div class="stat-lbl">WPM</div><div class="stat-val wpm" id="wpm-val">0</div><div class="stat-unit">words/min</div></div>
      <div class="stat-box acc-box"><div class="stat-lbl">Accuracy</div><div class="stat-val acc" id="acc-val">100</div><div class="stat-unit">percent %</div></div>
      <div class="stat-box time-box"><div class="stat-lbl">Time Left</div><div class="stat-val timer" id="time-val">30</div><div class="stat-unit">seconds</div></div>
      <div class="stat-box keys-box"><div class="stat-lbl">Keystrokes</div><div class="stat-val keys" id="keys-val">0</div><div class="stat-unit">typed</div></div>
    </div>

    <div class="prog-bar"><div class="prog-fill" id="prog-fill"></div></div>

    <div class="type-box" id="type-box" onclick="focusSolo()">
      <div class="chunk-indicator">
        <span style="color:var(--text2)">Paragraph</span>
        <div class="chunk-dots" id="chunk-dots"></div>
      </div>
      <div id="text-display"></div>
      <input type="text" id="hidden-input" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false">
      <div class="type-hint"><i class="fa-regular fa-keyboard"></i> Click here or press any key to start typing</div>
    </div>

    <div class="result-panel" id="result-panel">
      <div class="result-emoji" id="result-emoji">🎉</div>
      <div class="result-title" id="result-title">Test Complete!</div>
      <div class="result-sub" id="result-sub">Here are your results</div>
      <div class="result-stats">
        <div class="rs"><div class="rs-num" style="color:var(--accent3)" id="final-wpm">0</div><div class="rs-lbl">WPM</div></div>
        <div class="rs"><div class="rs-num" style="color:var(--green)" id="final-acc">0%</div><div class="rs-lbl">Accuracy</div></div>
        <div class="rs"><div class="rs-num" id="final-correct">0</div><div class="rs-lbl">Correct</div></div>
        <div class="rs"><div class="rs-num" style="color:var(--red)" id="final-wrong">0</div><div class="rs-lbl">Errors</div></div>
        <div class="rs"><div class="rs-num" style="color:var(--blue)" id="final-paras">0</div><div class="rs-lbl">Paragraphs</div></div>
      </div>
      <button class="btn-restart" onclick="resetSolo()">↺ Try Again</button>
    </div>
  </div>

  <!-- MULTIPLAYER PANEL -->
  <div class="multi-panel" id="multi-panel">
    <div class="multi-layout">
      <div class="room-sidebar">
        <div class="section-title">Room</div>
        <div class="room-actions">
          <button class="btn-create" onclick="createRoom()"><i class="fa-solid fa-plus"></i> Create Room</button>
          <div class="join-form">
            <input class="join-input" id="room-code-input" placeholder="ABC123" maxlength="6">
            <button class="btn-join" onclick="joinRoom()">Join →</button>
          </div>
        </div>

        <div class="room-info" id="room-info">
          <div class="section-title">Room Code</div>
          <div class="room-code-display" id="room-code-show">------</div>
          <div id="room-status-badge" class="room-status-badge badge-waiting"><span class="dot" style="width:6px;height:6px;border-radius:50%;background:currentColor"></span> Waiting for players</div>

          <div id="race-settings" style="margin:14px 0 0">
            <div style="font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px">Mode</div>
            <div class="ctrl-group" id="multi-mode-group" style="width:100%;margin-bottom:10px">
              <button class="ctrl-btn active" onclick="setRaceMode('normal',this)">Normal</button>
              <button class="ctrl-btn" onclick="setRaceMode('punctuation',this)">@ Punct</button>
              <button class="ctrl-btn" onclick="setRaceMode('numbers',this)"># Nums</button>
            </div>
            <div style="font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px">Time Limit</div>
            <div class="ctrl-group" id="multi-time-group" style="width:100%">
              <button class="ctrl-btn" onclick="setRaceTime(15,this)">15s</button>
              <button class="ctrl-btn" onclick="setRaceTime(30,this)">30s</button>
              <button class="ctrl-btn active" onclick="setRaceTime(60,this)">60s</button>
              <button class="ctrl-btn" onclick="setRaceTime(120,this)">120s</button>
            </div>
          </div>

          <button class="btn-start" id="btn-start-race" onclick="startRace()" style="margin-top:14px"><i class="fa-solid fa-flag-checkered"></i> Start Race!</button>
        </div>

        <div class="section-title" id="players-lbl" style="display:none">Players</div>
        <div class="players-list" id="players-list"></div>

        <div class="chat-panel" id="chat-panel">
          <div class="chat-header"><i class="fa-regular fa-message"></i> Room Chat</div>
          <div class="chat-messages" id="chat-messages"></div>
          <div class="chat-input-row">
            <input class="chat-input" id="chat-input" placeholder="Say something..." maxlength="200" autocomplete="off">
            <button class="chat-send" id="chat-send-btn" onclick="sendChat()"><i class="fa-solid fa-paper-plane"></i></button>
          </div>
        </div>
      </div>

      <div class="race-main" style="position:relative">
        <div class="countdown-overlay" id="countdown-overlay">
          <div class="countdown-num" id="countdown-num">3</div>
          <div class="countdown-msg">Get ready to race!</div>
        </div>

        <div id="race-idle" style="text-align:center;padding:60px 20px">
          <div style="font-size:48px;margin-bottom:16px">🏎</div>
          <div style="font-family:var(--mono);font-size:20px;font-weight:700;margin-bottom:8px">Ready to Race?</div>
          <div style="color:var(--text2);font-size:14px">Create or join a room to start a multiplayer typing race</div>
        </div>

        <div id="race-lobby" style="display:none">
          <div class="section-title">Race Track</div>
          <div class="race-track-area" id="race-tracks"></div>

          <!-- RACE TYPING BOX — now with full highlight support -->
          <div class="race-text-box" id="race-text-box">
            <div class="section-title">Type this text</div>
            <div class="type-box focused" id="race-type-box" onclick="focusRaceInput()">
              <div id="race-text-display"></div>
              <input type="text" id="race-hidden-input"
                autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                style="opacity:0;position:absolute;height:0;width:0;pointer-events:none">
              <div class="type-hint"><i class="fa-solid fa-bolt"></i> Race started! Type as fast as you can!</div>
            </div>
            <div class="stats-grid" style="margin-top:16px;grid-template-columns:repeat(5,1fr)">
              <div class="stat-box"><div class="stat-lbl">My WPM</div><div class="stat-val wpm" id="race-wpm">0</div></div>
              <div class="stat-box"><div class="stat-lbl">Accuracy</div><div class="stat-val acc" id="race-acc">100</div></div>
              <div class="stat-box"><div class="stat-lbl">Progress</div><div class="stat-val" style="color:var(--blue)" id="race-prog">0%</div></div>
              <div class="stat-box"><div class="stat-lbl">Position</div><div class="stat-val" style="color:var(--amber)" id="race-pos">#-</div></div>
              <div class="stat-box time-box"><div class="stat-lbl" id="race-time-lbl">Time</div><div class="stat-val timer" id="race-time">0:00</div><div class="stat-unit" id="race-time-unit">elapsed</div></div>
            </div>
          </div>
        </div>

        <div class="multi-result" id="multi-result">
          <div class="section-title" style="text-align:center;margin-bottom:20px">🏆 Race Results</div>
          <div class="podium" id="result-podium"></div>
          <div id="result-full-list" style="margin-bottom:20px"></div>
          <div style="display:flex;gap:10px;justify-content:center">
            <button class="btn-new-race" onclick="restartRace()"><i class="fa-solid fa-rotate-right"></i> Play Again</button>
            <button class="btn-new-race" onclick="leaveRace()" style="background:var(--surface);border:1px solid var(--border);color:var(--text2)"><i class="fa-solid fa-right-from-bracket"></i> Leave Room</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
var ME = {
  username: '<%= user.username %>',
  id: <%= user.id %>,
  color: '<%= user.avatar_color %>'
};
var socket = io();

// ─── WORD BANK ────────────────────────────────────────────────────────────
var WORD_BANK = [
  'the','be','to','of','and','a','in','that','have','it','for','not','on','with',
  'he','as','you','do','at','this','but','his','by','from','they','we','say','her',
  'she','or','an','will','my','one','all','would','there','their','what','so','up',
  'out','if','about','who','get','which','go','me','when','make','can','like','time',
  'no','just','him','know','take','people','into','year','your','good','some','could',
  'them','see','other','than','then','now','look','only','come','its','over','think',
  'also','back','after','use','two','how','our','work','first','well','way','even',
  'new','want','because','any','these','give','day','most','us','great','between',
  'need','large','often','hand','high','place','hold','turn','were','said','each',
  'tell','does','set','three','air','put','end','why','again','off','play','small',
  'number','always','move','live','show','try','around','another','home','old',
  'world','life','few','open','seem','together','next','white','begin','got','walk',
  'paper','group','music','both','mark','book','letter','until','mile','river','car',
  'feet','care','second','enough','eat','face','watch','far','real','almost','let',
  'above','girl','sometimes','mountain','cut','young','talk','soon','list','song',
  'leave','family','body','light','voice','power','town','fine','drive','short',
  'road','true','common','stop','once','hear','sure','four','head','black','force',
  'near','since','plan','figure','star','box','field','rest','able','done','beauty',
  'front','teach','week','final','green','quick','develop','ocean','warm','free',
  'minute','strong','special','clear','tail','produce','fact','street','inch','lot',
  'course','stay','wheel','full','blue','object','decide','surface','deep','moon',
  'island','foot','yet','busy','test','record','boat','gold','possible','plane',
  'age','dry','wonder','laugh','thousand','ago','ran','check','game','shape',
  'bring','paint','language','among','point','form','stand','own','page','should',
  'country','found','still','learn','plant','cover','food','sun','four','between',
  'state','never','became','side','cry','check','simple','cell','paint','mind',
  'love','cause','rain','exercise','wall','catch','mount','wish','drop','ground'
];

var NUM_BANK = [
  '42','100','256','1024','7','13','99','365','1000','2048',
  '3','16','64','512','8','24','48','128','200','500'
];

var PUNCT_PAIRS = [
  [', ',' '],['! ',' '],['? ',' '],['... ',' '],['— ',' '],['; ',' ']
];

function generateWords(count, mode) {
  var words = [];
  for (var i = 0; i < count; i++) {
    if (mode === 'numbers' && Math.random() < 0.22) {
      words.push(NUM_BANK[Math.floor(Math.random() * NUM_BANK.length)]);
    } else {
      words.push(WORD_BANK[Math.floor(Math.random() * WORD_BANK.length)]);
    }
  }
  if (mode === 'punctuation') {
    var result = '';
    for (var j = 0; j < words.length; j++) {
      result += words[j];
      if (j < words.length - 1) {
        if (Math.random() < 0.18) {
          var p = PUNCT_PAIRS[Math.floor(Math.random() * PUNCT_PAIRS.length)];
          result += p[0];
        } else {
          result += ' ';
        }
      }
    }
    return result;
  }
  return words.join(' ');
}

// ─── SOLO STATE ───────────────────────────────────────────────────────────
var soloTime = 30;
var soloTextMode = 'normal';
var soloCurrentText = '';
var soloTimer = null;
var soloStarted = false;
var soloTimeLeft = 30;
var soloStartTs = null;
var soloChunks = [];
var soloChunkIndex = 0;
var soloTotalTyped = 0;
var soloTotalCorrect = 0;
var soloTotalWrong = 0;
var soloCompletedParas = 0;

// ─── SHARED HELPERS ───────────────────────────────────────────────────────
function renderText(text, typed) {
  var html = '';
  for (var i = 0; i < text.length; i++) {
    var ch = text[i];
    var cls = 'pending';
    if (i < typed.length) {
      cls = typed[i] === ch ? 'correct' : 'wrong';
    } else if (i === typed.length) {
      cls = 'current';
    }
    var display = ch === ' ' ? '&nbsp;' : ch;
    html += '<span class="' + cls + '">' + display + '</span>';
  }
  return html;
}

function calcWPMFromChars(totalChars, elapsedSeconds) {
  if (elapsedSeconds <= 0) return 0;
  return Math.round((totalChars / 5) / (elapsedSeconds / 60));
}

function calcAcc(typed, ref) {
  if (!typed.length) return 100;
  var ok = 0;
  for (var i = 0; i < typed.length; i++) {
    if (typed[i] === ref[i]) ok++;
  }
  return Math.round(ok / typed.length * 100);
}

function calcDetails(typed, ref) {
  var ok = 0, bad = 0;
  for (var i = 0; i < typed.length; i++) {
    if (typed[i] === ref[i]) ok++;
    else bad++;
  }
  return { ok: ok, bad: bad };
}

// ─── SOLO FUNCTIONS ───────────────────────────────────────────────────────
function getShuffledTexts(mode) {
  var chunks = [];
  for (var i = 0; i < 5; i++) {
    chunks.push(generateWords(30, mode));
  }
  return chunks;
}

function updateChunkDots() {
  var total = soloChunks.length;
  var html = '';
  for (var i = 0; i < total; i++) {
    var cls = 'chunk-dot';
    if (i < soloChunkIndex) cls += ' done';
    else if (i === soloChunkIndex) cls += ' active';
    html += '<div class="' + cls + '"></div>';
  }
  document.getElementById('chunk-dots').innerHTML = html;
}

function loadChunk(index) {
  soloCurrentText = soloChunks[index % soloChunks.length];
  document.getElementById('text-display').innerHTML = renderText(soloCurrentText, '');
  document.getElementById('hidden-input').value = '';
  updateChunkDots();
}

function initSolo() {
  soloChunks = getShuffledTexts(soloTextMode);
  soloChunkIndex = 0;
  soloTotalTyped = 0;
  soloTotalCorrect = 0;
  soloTotalWrong = 0;
  soloCompletedParas = 0;
  soloTimeLeft = soloTime;
  soloStarted = false;
  soloStartTs = null;
  if (soloTimer) clearInterval(soloTimer);
  document.getElementById('result-panel').style.display = 'none';
  document.getElementById('type-box').style.display = 'block';
  document.getElementById('hidden-input').value = '';
  document.getElementById('wpm-val').textContent = '0';
  document.getElementById('acc-val').textContent = '100';
  document.getElementById('time-val').textContent = soloTime;
  document.getElementById('keys-val').textContent = '0';
  document.getElementById('prog-fill').style.width = '0%';
  loadChunk(0);
}

function focusSolo() {
  document.getElementById('hidden-input').focus();
}

function selectTime(t, btn) {
  soloTime = t;
  document.getElementById('time-ctrl-group').querySelectorAll('.ctrl-btn').forEach(function(b) {
    b.classList.remove('active');
  });
  btn.classList.add('active');
  initSolo();
}

function selectTextMode(m, btn) {
  soloTextMode = m;
  document.getElementById('mode-ctrl-group').querySelectorAll('.ctrl-btn').forEach(function(b) {
    b.classList.remove('active');
  });
  btn.classList.add('active');
  initSolo();
}

function resetSolo() {
  initSolo();
  focusSolo();
}

document.getElementById('hidden-input').addEventListener('input', function() {
  var typed = this.value;
  var refText = soloCurrentText;

  if (!soloStarted && typed.length > 0) {
    soloStarted = true;
    soloStartTs = Date.now();
    soloTimer = setInterval(function() {
      soloTimeLeft--;
      document.getElementById('time-val').textContent = soloTimeLeft;
      document.getElementById('prog-fill').style.width = ((soloTime - soloTimeLeft) / soloTime * 100) + '%';
      var elapsed = (Date.now() - soloStartTs) / 1000;
      var currentTyped = document.getElementById('hidden-input').value;
      var wpm = calcWPMFromChars(soloTotalTyped + currentTyped.length, elapsed);
      document.getElementById('wpm-val').textContent = wpm;
      if (soloTimeLeft <= 0) {
        clearInterval(soloTimer);
        finishSolo();
      }
    }, 1000);
  }

  if (!soloStarted) return;

  var elapsed = (Date.now() - soloStartTs) / 1000;
  var totalCharsNow = soloTotalTyped + typed.length;
  var wpm = calcWPMFromChars(totalCharsNow, elapsed);
  var acc = calcAcc(typed, refText);

  document.getElementById('wpm-val').textContent = wpm;
  document.getElementById('acc-val').textContent = acc;
  document.getElementById('keys-val').textContent = totalCharsNow;
  document.getElementById('text-display').innerHTML = renderText(refText, typed);

  if (typed === refText) {
    var details = calcDetails(typed, refText);
    soloTotalTyped += typed.length;
    soloTotalCorrect += details.ok;
    soloTotalWrong += details.bad;
    soloCompletedParas++;
    soloChunkIndex++;
    if (soloChunkIndex >= soloChunks.length) {
      soloChunks = getShuffledTexts(soloTextMode);
      soloChunkIndex = 0;
    }
    loadChunk(soloChunkIndex);
  }
});

async function finishSolo() {
  document.getElementById('hidden-input').blur();
  var partialTyped = document.getElementById('hidden-input').value;
  var partialDetails = calcDetails(partialTyped, soloCurrentText);

  var totalTyped = soloTotalTyped + partialTyped.length;
  var totalCorrect = soloTotalCorrect + partialDetails.ok;
  var totalWrong = soloTotalWrong + partialDetails.bad;
  var elapsed = soloStartTs ? (Date.now() - soloStartTs) / 1000 : soloTime;
  var wpm = calcWPMFromChars(totalTyped, elapsed);
  var acc = totalTyped > 0 ? Math.round(totalCorrect / totalTyped * 100) : 100;

  document.getElementById('type-box').style.display = 'none';
  document.getElementById('result-panel').style.display = 'block';
  document.getElementById('final-wpm').textContent = wpm;
  document.getElementById('final-acc').textContent = acc + '%';
  document.getElementById('final-correct').textContent = totalCorrect;
  document.getElementById('final-wrong').textContent = totalWrong;
  document.getElementById('final-paras').textContent = soloCompletedParas;

  if (wpm >= 70) {
    document.getElementById('result-emoji').textContent = '🔥';
    document.getElementById('result-title').textContent = 'Blazing Fast!';
    document.getElementById('result-sub').textContent = 'You are in the top tier of typists!';
  } else if (wpm >= 50) {
    document.getElementById('result-emoji').textContent = '⚡';
    document.getElementById('result-title').textContent = 'Excellent Speed!';
    document.getElementById('result-sub').textContent = 'Above average — keep pushing!';
  } else if (wpm >= 35) {
    document.getElementById('result-emoji').textContent = '👍';
    document.getElementById('result-title').textContent = 'Good Job!';
    document.getElementById('result-sub').textContent = 'You are at average speed. Keep practicing!';
  } else {
    document.getElementById('result-emoji').textContent = '💪';
    document.getElementById('result-title').textContent = 'Keep Practicing!';
    document.getElementById('result-sub').textContent = 'Regular practice will improve your speed fast.';
  }

  if (soloStarted) {
    try {
      await fetch('/api/solo-result', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          wpm: wpm, accuracy: acc,
          correct_chars: totalCorrect, wrong_chars: totalWrong,
          total_chars: totalTyped, duration_seconds: Math.round(elapsed),
          mode: soloTextMode
        })
      });
    } catch(e) {}
  }
}

// ─── GLOBAL KEYDOWN — keeps correct input focused ─────────────────────────
document.addEventListener('keydown', function(e) {
  if (e.key.length !== 1) return;
  var soloIp = document.getElementById('hidden-input');
  var raceIp = document.getElementById('race-hidden-input');

  if (document.getElementById('solo-panel').classList.contains('show') &&
      document.activeElement !== soloIp) {
    soloIp.focus();
  }

  if (document.getElementById('multi-panel').classList.contains('show') &&
      raceStarted && !raceIp.disabled && document.activeElement !== raceIp) {
    raceIp.focus();
  }
});

// ─── MULTIPLAYER STATE ────────────────────────────────────────────────────
var currentRoom = null;
var isHost = false;
var raceText = '';
var raceStarted = false;
var raceStartTs = null;
var raceTimer = null;
var raceElapsed = 0;
var raceMode = 'normal';
var raceTimeLimit = 60;
var currentRaceTimeLimit = 60;

function setRaceMode(m, btn) {
  if (!isHost) return;
  raceMode = m;
  document.getElementById('multi-mode-group').querySelectorAll('.ctrl-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
}

function setRaceTime(t, btn) {
  if (!isHost) return;
  raceTimeLimit = t;
  document.getElementById('multi-time-group').querySelectorAll('.ctrl-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
}

function syncSettingsUI(textMode, timeLimit, editable) {
  var mg = document.getElementById('multi-mode-group');
  var tg = document.getElementById('multi-time-group');
  mg.querySelectorAll('.ctrl-btn').forEach(function(b) {
    b.classList.remove('active');
    b.disabled = !editable;
    b.style.opacity = editable ? '' : '0.5';
    b.style.cursor = editable ? '' : 'default';
  });
  tg.querySelectorAll('.ctrl-btn').forEach(function(b) {
    b.classList.remove('active');
    b.disabled = !editable;
    b.style.opacity = editable ? '' : '0.5';
    b.style.cursor = editable ? '' : 'default';
  });
  var modeMap = {'normal':0,'punctuation':1,'numbers':2};
  var timeMap = {15:0,30:1,60:2,120:3};
  if (modeMap[textMode] !== undefined) mg.querySelectorAll('.ctrl-btn')[modeMap[textMode]].classList.add('active');
  if (timeMap[timeLimit] !== undefined) tg.querySelectorAll('.ctrl-btn')[timeMap[timeLimit]].classList.add('active');
}

// ─── CHAT ─────────────────────────────────────────────────────────────────
function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function appendChatMsg(data) {
  var el = document.getElementById('chat-messages');
  var isMe = data.username === ME.username;
  var html = '<div class="chat-msg ' + (isMe ? 'mine' : '') + '">' +
    '<div class="chat-avatar" style="background:' + escapeHtml(data.color || '#7c3aed') + '">' + escapeHtml(data.username[0].toUpperCase()) + '</div>' +
    '<div class="chat-bubble">' +
      (!isMe ? '<div class="chat-name">' + escapeHtml(data.username) + (data.isHost ? ' <i class="fa-solid fa-crown" style="color:var(--amber);font-size:9px"></i>' : '') + '</div>' : '') +
      '<div class="chat-text">' + escapeHtml(data.text) + '</div>' +
    '</div>' +
    '</div>';
  el.insertAdjacentHTML('beforeend', html);
  el.scrollTop = el.scrollHeight;
}

function appendSystemMsg(text) {
  var el = document.getElementById('chat-messages');
  el.insertAdjacentHTML('beforeend', '<div class="chat-system-msg">— ' + escapeHtml(text) + ' —</div>');
  el.scrollTop = el.scrollHeight;
}

function sendChat() {
  var input = document.getElementById('chat-input');
  var text = input.value.trim();
  if (!text || !currentRoom) return;
  socket.emit('chat_message', { roomCode: currentRoom, text: text });
  input.value = '';
}

document.getElementById('chat-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') { e.preventDefault(); sendChat(); }
});

socket.on('chat_message', function(data) { appendChatMsg(data); });
socket.on('chat_system', function(data) { appendSystemMsg(data.text); });

function showChat() {
  document.getElementById('chat-panel').style.display = 'block';
}

function hideChat() {
  document.getElementById('chat-panel').style.display = 'none';
  document.getElementById('chat-messages').innerHTML = '';
  document.getElementById('chat-input').value = '';
}

function createRoom() {
  if (currentRoom) socket.emit('leave_room', { roomCode: currentRoom });
  socket.emit('create_room');
}

function joinRoom() {
  var code = document.getElementById('room-code-input').value.trim().toUpperCase();
  if (code.length < 4) return toast('Enter a valid room code', 'error');
  if (currentRoom) socket.emit('leave_room', { roomCode: currentRoom });
  socket.emit('join_room', { roomCode: code });
}

function startRace() {
  if (currentRoom) socket.emit('start_race', { roomCode: currentRoom, textMode: raceMode, timeLimit: raceTimeLimit });
}

socket.on('room_created', function(data) {
  currentRoom = data.roomCode;
  isHost = true;
  raceText = data.text || '';
  raceMode = 'normal'; raceTimeLimit = 60;
  document.getElementById('room-info').style.display = 'block';
  document.getElementById('room-code-show').textContent = data.roomCode;
  document.getElementById('players-lbl').style.display = 'block';
  document.getElementById('btn-start-race').style.display = 'block';
  document.getElementById('race-idle').style.display = 'none';
  document.getElementById('race-lobby').style.display = 'block';
  syncSettingsUI('normal', 60, true);
  showChat();
  appendSystemMsg('Room created — invite friends with code ' + data.roomCode);
  toast('Room created: ' + data.roomCode, 'success');
});

socket.on('room_joined', function(data) {
  currentRoom = data.roomCode;
  isHost = false;
  raceText = data.text || '';
  document.getElementById('room-info').style.display = 'block';
  document.getElementById('room-code-show').textContent = data.roomCode;
  document.getElementById('players-lbl').style.display = 'block';
  document.getElementById('race-idle').style.display = 'none';
  document.getElementById('race-lobby').style.display = 'block';
  syncSettingsUI('normal', 60, false);
  showChat();
  toast('Joined room ' + data.roomCode, 'success');
});

socket.on('join_error', function(msg) { toast(msg, 'error'); });
socket.on('error', function(msg) { toast(msg, 'error'); });

socket.on('room_state', function(data) {
  renderPlayersList(data.players, data.hostId);
  renderRaceTracks(data.players);
  if (data.hostId === ME.id) {
    document.getElementById('btn-start-race').style.display = 'block';
    syncSettingsUI(data.textMode || 'normal', data.timeLimit || 60, true);
  } else {
    syncSettingsUI(data.textMode || 'normal', data.timeLimit || 60, false);
  }
});

socket.on('players_update', function(players) {
  renderRaceTracks(players);
  for (var i = 0; i < players.length; i++) {
    if (players[i].userId === ME.id && raceStarted) {
      document.getElementById('race-pos').textContent = '#' + (i + 1);
      break;
    }
  }
});

socket.on('countdown_start', function() {
  document.getElementById('countdown-overlay').style.display = 'flex';
  document.getElementById('race-text-box').style.display = 'none';
  document.getElementById('room-status-badge').innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block"></span> Starting...';
  document.getElementById('room-status-badge').className = 'room-status-badge badge-racing';
});

socket.on('countdown_tick', function(n) {
  var el = document.getElementById('countdown-num');
  el.textContent = n > 0 ? n : 'GO!';
  el.style.animation = 'none';
  el.offsetHeight; // reflow to restart animation
  el.style.animation = 'pulse .8s ease';
  el.style.color = n > 0 ? 'var(--amber)' : 'var(--green)';
});

socket.on('race_start', function(data) {
  raceText = data.text;
  raceStarted = true;
  raceStartTs = Date.now();
  currentRaceTimeLimit = data.timeLimit || 0;

  document.getElementById('countdown-overlay').style.display = 'none';
  document.getElementById('race-text-box').style.display = 'block';

  document.getElementById('race-text-display').innerHTML = renderText(raceText, '');

  var raceInp = document.getElementById('race-hidden-input');
  raceInp.disabled = false;
  raceInp.value = '';

  document.getElementById('race-wpm').textContent = '0';
  document.getElementById('race-acc').textContent = '100';
  document.getElementById('race-prog').textContent = '0%';
  document.getElementById('race-pos').textContent = '#-';
  document.getElementById('race-time').textContent = currentRaceTimeLimit > 0
    ? (Math.floor(currentRaceTimeLimit/60) + ':' + (currentRaceTimeLimit%60 < 10 ? '0' : '') + currentRaceTimeLimit%60)
    : '0:00';
  document.getElementById('race-time-lbl').textContent = currentRaceTimeLimit > 0 ? 'Time Left' : 'Time';
  document.getElementById('race-time-unit').textContent = currentRaceTimeLimit > 0 ? 'remaining' : 'elapsed';

  if (raceTimer) clearInterval(raceTimer);
  raceElapsed = 0;
  raceTimer = setInterval(function() {
    raceElapsed++;
    var display, m, s;
    if (currentRaceTimeLimit > 0) {
      var remaining = Math.max(0, currentRaceTimeLimit - raceElapsed);
      m = Math.floor(remaining / 60); s = remaining % 60;
      display = m + ':' + (s < 10 ? '0' : '') + s;
      if (remaining <= 10) document.getElementById('race-time').style.color = 'var(--red)';
    } else {
      m = Math.floor(raceElapsed / 60); s = raceElapsed % 60;
      display = m + ':' + (s < 10 ? '0' : '') + s;
    }
    document.getElementById('race-time').textContent = display;
  }, 1000);

  document.getElementById('room-status-badge').innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;animation:caretBlink .8s ease infinite"></span> Racing!';

  appendSystemMsg('Race started — good luck!');
  focusRaceInput();
  toast('GO! Type as fast as you can!', 'info');
});

socket.on('player_completed', function(data) {
  if (data.username !== ME.username) {
    toast(data.username + ' finished #' + data.position + ' — ' + data.wpm + ' WPM', 'info');
  }
});

socket.on('race_finished', function(data) {
  raceStarted = false;
  if (raceTimer) { clearInterval(raceTimer); raceTimer = null; }
  document.getElementById('race-text-box').style.display = 'none';
  document.getElementById('multi-result').style.display = 'block';
  renderFinalResults(data.players);
  var winner = data.players[0];
  if (winner) appendSystemMsg('Race over! ' + winner.username + ' wins with ' + winner.wpm + ' WPM');
});

socket.on('player_left', function(data) { toast(data.username + ' left the room', 'error'); });

socket.on('room_reset', function(data) {
  raceText = data.text;
  raceStarted = false;
  raceStartTs = null;
  if (raceTimer) { clearInterval(raceTimer); raceTimer = null; }
  raceElapsed = 0;
  document.getElementById('race-time').textContent = '0:00';
  document.getElementById('multi-result').style.display = 'none';
  document.getElementById('race-text-box').style.display = 'none';
  document.getElementById('countdown-overlay').style.display = 'none';
  document.getElementById('race-lobby').style.display = 'block';
  document.getElementById('race-hidden-input').disabled = false;
  document.getElementById('race-hidden-input').value = '';
  document.getElementById('race-text-display').innerHTML = '';
  document.getElementById('room-status-badge').innerHTML = '<span style="width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block"></span> Waiting for players';
  document.getElementById('room-status-badge').className = 'room-status-badge badge-waiting';
  document.getElementById('race-time').style.color = '';
  if (isHost) {
    document.getElementById('btn-start-race').style.display = 'block';
    syncSettingsUI(data.textMode || raceMode, data.timeLimit || raceTimeLimit, true);
  } else {
    syncSettingsUI(data.textMode || 'normal', data.timeLimit || 60, false);
  }
  toast('Race reset! Host can start a new race.', 'info');
});

socket.on('new_host', function(data) {
  if (data.username === ME.username) {
    isHost = true;
    document.getElementById('btn-start-race').style.display = 'block';
    syncSettingsUI(raceMode, raceTimeLimit, true);
    toast('You are now the host — configure settings and start the race', 'info');
  }
});

// ─── RACE INPUT — with live correct/wrong/cursor highlighting ─────────────
document.getElementById('race-hidden-input').addEventListener('input', function() {
  if (!raceStarted) return;
  var typed = this.value;
  var acc = calcAcc(typed, raceText);
  var elapsed = (Date.now() - raceStartTs) / 1000;
  var wpm = calcWPMFromChars(typed.length, elapsed);
  var prog = Math.round(typed.length / raceText.length * 100);

  // Live character-by-character highlighting — same as solo
  document.getElementById('race-text-display').innerHTML = renderText(raceText, typed);

  document.getElementById('race-wpm').textContent = wpm;
  document.getElementById('race-acc').textContent = acc;
  document.getElementById('race-prog').textContent = prog + '%';

  if (currentRoom) {
    socket.emit('progress_update', { roomCode: currentRoom, progress: prog, wpm: wpm, accuracy: acc });
  }

  if (typed.length >= raceText.length) {
    var finalTyped = typed.slice(0, raceText.length);
    this.value = finalTyped;
    var finalAcc = calcAcc(finalTyped, raceText);
    var finalWpm = calcWPMFromChars(finalTyped.length, (Date.now() - raceStartTs) / 1000);
    var finishMs = Date.now() - raceStartTs;
    socket.emit('player_finished', { roomCode: currentRoom, wpm: finalWpm, accuracy: finalAcc, finishTimeMs: finishMs });
    this.disabled = true;
    document.getElementById('race-text-display').innerHTML = renderText(raceText, finalTyped);
    toast('You finished! 🎉', 'success');
  }
});

function focusRaceInput() {
  var inp = document.getElementById('race-hidden-input');
  if (inp && !inp.disabled) inp.focus();
}

// ─── RENDER HELPERS ───────────────────────────────────────────────────────
function renderPlayersList(players, hostId) {
  var el = document.getElementById('players-list');
  var html = '';
  for (var i = 0; i < players.length; i++) {
    var p = players[i];
    html += '<div class="player-item">' +
      '<div class="p-avatar" style="background:' + (p.avatar_color || '#7c3aed') + '">' + p.username[0].toUpperCase() + '</div>' +
      '<span class="p-name">' + p.username + (hostId === p.userId ? ' <i class="fa-solid fa-crown" style="color:var(--amber);font-size:10px"></i>' : '') + '</span>' +
      (p.userId === ME.id ? '<span class="p-you">You</span>' : '') +
      '<span class="p-wpm">' + (p.wpm > 0 ? p.wpm + ' wpm' : '') + '</span>' +
      '</div>';
  }
  el.innerHTML = html;
}

var TRACK_COLORS = ['#7c3aed','#10b981','#f59e0b','#3b82f6','#ef4444','#ec4899'];

function renderRaceTracks(players) {
  var el = document.getElementById('race-tracks');
  var html = '';
  for (var i = 0; i < players.length; i++) {
    var p = players[i];
    var isMe = p.userId === ME.id;
    var name = isMe ? '<b>' + p.username + '</b>' : p.username;
    html += '<div class="race-track">' +
      '<div class="track-player" title="' + p.username + '">' + name + '</div>' +
      '<div class="track-bar">' +
        '<div class="track-fill" style="width:' + Math.max(p.progress, 2) + '%;background:' + TRACK_COLORS[i % 6] + '30;border-right:3px solid ' + TRACK_COLORS[i % 6] + '">' +
          '<span style="font-size:16px;position:absolute;right:-8px">🏎</span>' +
        '</div>' +
      '</div>' +
      '<div class="track-wpm">' + (p.wpm > 0 ? p.wpm + ' wpm' : '---') + '</div>' +
      '</div>';
  }
  el.innerHTML = html;
}

function renderFinalResults(players) {
  var sorted = players.slice().sort(function(a, b) {
    return b.progress - a.progress || b.wpm - a.wpm;
  });
  var medals = ['🥇','🥈','🥉'];
  var podiumEl = document.getElementById('result-podium');
  var podiumOrder = sorted.length >= 3 ? [sorted[1], sorted[0], sorted[2]] : sorted;
  var podiumHtml = '';
  for (var i = 0; i < podiumOrder.length; i++) {
    var p = podiumOrder[i];
    var rank = sorted.indexOf(p) + 1;
    var heights = [70, 100, 50];
    var h = heights[i] || 50;
    podiumHtml += '<div class="podium-item podium-' + rank + '">' +
      '<div class="podium-bar" style="height:' + h + 'px">' + (medals[rank-1] || rank) + '</div>' +
      '<div class="podium-name">' + p.username + '</div>' +
      '<div class="podium-wpm">' + p.wpm + ' wpm</div>' +
      '</div>';
  }
  podiumEl.innerHTML = podiumHtml;

  var listHtml = '<table style="width:100%;border-collapse:collapse;font-size:14px">' +
    '<tr style="color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.5px">' +
    '<td style="padding:8px">Pos</td><td>Player</td><td style="text-align:right">WPM</td><td style="text-align:right">Accuracy</td></tr>';
  for (var j = 0; j < sorted.length; j++) {
    var sp = sorted[j];
    listHtml += '<tr style="border-top:1px solid var(--border)">' +
      '<td style="padding:10px 8px;font-family:var(--mono)">' + (medals[j] || ('#' + (j+1))) + '</td>' +
      '<td><div style="display:flex;align-items:center;gap:8px">' +
        '<div style="width:24px;height:24px;border-radius:50%;background:' + (sp.avatar_color || '#7c3aed') + ';display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff">' +
        sp.username[0].toUpperCase() + '</div>' +
        sp.username + (sp.userId === ME.id ? ' <span style="font-size:10px;color:var(--accent3)">(you)</span>' : '') +
      '</div></td>' +
      '<td style="text-align:right;font-family:var(--mono);color:var(--accent3)">' + sp.wpm + '</td>' +
      '<td style="text-align:right;font-family:var(--mono);color:var(--green)">' + sp.accuracy + '%</td>' +
      '</tr>';
  }
  listHtml += '</table>';
  document.getElementById('result-full-list').innerHTML = listHtml;
}

function leaveRace() {
  if (currentRoom) socket.emit('leave_room', { roomCode: currentRoom });
  if (raceTimer) { clearInterval(raceTimer); raceTimer = null; }
  raceElapsed = 0; raceMode = 'normal'; raceTimeLimit = 60; currentRaceTimeLimit = 0;
  document.getElementById('race-time').style.color = '';
  hideChat();
  currentRoom = null; isHost = false; raceStarted = false;
  document.getElementById('room-info').style.display = 'none';
  document.getElementById('players-lbl').style.display = 'none';
  document.getElementById('race-idle').style.display = 'block';
  document.getElementById('race-lobby').style.display = 'none';
  document.getElementById('multi-result').style.display = 'none';
  document.getElementById('race-text-box').style.display = 'none';
  document.getElementById('players-list').innerHTML = '';
  document.getElementById('race-hidden-input').disabled = false;
  document.getElementById('race-hidden-input').value = '';
  document.getElementById('race-text-display').innerHTML = '';
  document.getElementById('btn-start-race').style.display = 'none';
}

function restartRace() {
  if (isHost) {
    socket.emit('reset_room', { roomCode: currentRoom });
  } else {
    toast('Waiting for the host to restart the race...', 'info');
  }
}

// ─── MODE SWITCH ──────────────────────────────────────────────────────────
function switchMode(mode, btn) {
  document.querySelectorAll('.mode-tab').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.getElementById('solo-panel').classList.toggle('show', mode === 'solo');
  document.getElementById('multi-panel').classList.toggle('show', mode === 'multi');
}

// ─── TOAST ────────────────────────────────────────────────────────────────
function toast(msg, type) {
  type = type || 'info';
  var el = document.createElement('div');
  el.className = 'toast-item ' + type;
  var icons = { success: '✓', error: '✗', info: 'ℹ' };
  el.innerHTML = '<span>' + (icons[type] || 'ℹ') + '</span><span>' + msg + '</span>';
  document.getElementById('toast').appendChild(el);
  setTimeout(function() { el.remove(); }, 3500);
}

initSolo();
</script>
</body>
</html>