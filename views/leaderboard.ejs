<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TypeFun – Leaderboard</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{
  --bg:#0a0a0f;--surface:#12121a;--card:#1a1a26;--border:#2a2a3d;
  --accent:#6d28d9;--accent2:#7c3aed;--accent3:#8b5cf6;--glow:rgba(109,40,217,0.2);
  --green:#10b981;--amber:#f59e0b;--red:#ef4444;--blue:#3b82f6;
  --text:#e8e8f0;--text2:#a0a0c0;--muted:#5a5a7a;
  --mono:'Space Mono',monospace;--sans:'DM Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh}
.bg-grid{position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:48px 48px;opacity:0.15;z-index:0;pointer-events:none}
nav{position:sticky;top:0;z-index:100;background:rgba(10,10,15,0.9);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 24px}
.nav-inner{max-width:1200px;margin:0 auto;height:60px;display:flex;align-items:center;gap:12px}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none}
.logo-icon{width:36px;height:36px;border-radius:10px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:700;font-size:14px;color:#fff}
.logo-text{font-family:var(--mono);font-size:17px;font-weight:700;color:var(--text)}
.logo-text span{color:var(--accent3)}
.nav-links{display:flex;gap:4px;margin-left:auto}
.nav-link{padding:7px 14px;border-radius:8px;font-size:13px;font-weight:500;color:var(--text2);text-decoration:none;transition:.2s;border:1px solid transparent}
.nav-link:hover{color:var(--text);background:var(--card);border-color:var(--border)}
.nav-link.active{color:var(--accent3);background:rgba(109,40,217,0.12);border-color:rgba(109,40,217,0.3)}
.user-chip{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);border-radius:99px;padding:5px 14px 5px 5px;margin-left:8px}
.avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff}
.page{max-width:1200px;margin:0 auto;padding:24px;position:relative;z-index:1}
.page-header{margin-bottom:28px;text-align:center}
.page-title{font-family:var(--mono);font-size:32px;font-weight:700;margin-bottom:8px}
.page-title span{color:var(--accent3)}
.page-sub{color:var(--text2);font-size:15px}
.tabs{display:flex;background:var(--surface);border-radius:12px;padding:4px;border:1px solid var(--border);width:fit-content;margin:0 auto 28px}
.tab{padding:9px 24px;border-radius:9px;font-size:14px;font-weight:500;cursor:pointer;transition:.2s;color:var(--text2);border:1px solid transparent}
.tab.active{background:var(--accent);color:#fff;box-shadow:0 0 20px var(--glow)}
.section{display:none}.section.show{display:block}

/* TOP 3 PODIUM */
.podium-section{display:flex;justify-content:center;align-items:flex-end;gap:12px;margin-bottom:32px;padding:20px}
.pod-wrap{text-align:center}
.pod-rank{font-size:28px;margin-bottom:8px}
.pod-avatar{width:56px;height:56px;border-radius:50%;margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:20px;font-weight:700;color:#fff;border:3px solid}
.pod-name{font-size:14px;font-weight:600;margin-bottom:2px;max-width:100px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pod-wpm{font-family:var(--mono);font-size:13px;color:var(--accent3)}
.pod-bar{width:90px;border-radius:8px 8px 0 0;margin:8px auto 0;display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--muted)}
.pod-1 .pod-bar{height:80px;background:linear-gradient(180deg,rgba(245,158,11,0.2),transparent);border:1px solid rgba(245,158,11,0.4)}
.pod-1 .pod-avatar{border-color:var(--amber);box-shadow:0 0 20px rgba(245,158,11,0.3)}
.pod-2 .pod-bar{height:56px;background:linear-gradient(180deg,rgba(148,163,184,0.15),transparent);border:1px solid rgba(148,163,184,0.3)}
.pod-2 .pod-avatar{border-color:#94a3b8;box-shadow:0 0 16px rgba(148,163,184,0.2)}
.pod-3 .pod-bar{height:40px;background:linear-gradient(180deg,rgba(180,83,9,0.15),transparent);border:1px solid rgba(180,83,9,0.3)}
.pod-3 .pod-avatar{border-color:#b45309;box-shadow:0 0 12px rgba(180,83,9,0.2)}

/* TABLE */
.lb-card{background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden}
table{width:100%;border-collapse:collapse;font-size:14px}
thead{background:var(--surface)}
th{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.5px;text-transform:uppercase;padding:12px 16px;text-align:left;border-bottom:1px solid var(--border)}
td{padding:12px 16px;border-bottom:1px solid rgba(42,42,61,0.4);color:var(--text2);transition:.15s}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(42,42,61,0.4);color:var(--text)}
.rank-num{font-family:var(--mono);font-weight:700;font-size:16px}
.td-wpm{font-family:var(--mono);color:var(--accent3)!important;font-weight:700}
.td-acc{font-family:var(--mono);color:var(--green)!important}
.td-wins{font-family:var(--mono);color:var(--amber)!important;font-weight:700}
.player-cell{display:flex;align-items:center;gap:10px}
.p-av{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.me-tag{font-size:10px;color:var(--accent3);padding:2px 8px;background:rgba(139,92,246,0.15);border-radius:99px;border:1px solid rgba(139,92,246,0.3)}
.empty{text-align:center;padding:48px;color:var(--muted)}
.empty i{font-size:40px;margin-bottom:12px;display:block}
</style>
</head>
<body>
<div class="bg-grid"></div>
<nav>
  <div class="nav-inner">
    <a href="/play" class="logo"><div class="logo-icon">TF</div><div class="logo-text">Type<span>Fun</span></div></a>
    <div class="nav-links">
      <a href="/play" class="nav-link"><i class="fa-solid fa-keyboard"></i> Play</a>
      <a href="/dashboard" class="nav-link"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
      <a href="/leaderboard" class="nav-link active"><i class="fa-solid fa-trophy"></i> Leaderboard</a>
    </div>
    <div class="user-chip" style="margin-left:auto">
      <div class="avatar" style="background:<%=user.avatar_color%>"><%=user.username[0].toUpperCase()%></div>
      <span style="font-size:13px;font-weight:500"><%=user.username%></span>
    </div>
    <a href="/logout" class="nav-link" style="margin-left:8px;color:var(--red)"><i class="fa-solid fa-right-from-bracket"></i></a>
  </div>
</nav>
<div class="page">
  <div class="page-header">
    <div class="page-title">🏆 <span>Leader</span>board</div>
    <div class="page-sub">Top typists across solo practice and multiplayer races</div>
  </div>
  <div class="tabs">
    <div class="tab active" onclick="switchTab('solo',this)"><i class="fa-solid fa-user"></i> Solo Rankings</div>
    <div class="tab" onclick="switchTab('multi',this)"><i class="fa-solid fa-users"></i> Race Rankings</div>
  </div>

  <!-- SOLO LEADERBOARD -->
  <div class="section show" id="tab-solo">
    <% if(soloTop && soloTop.length >= 3) { %>
    <div class="podium-section">
      <% const podOrder = soloTop.length>=2?[soloTop[1],soloTop[0],soloTop[2]||null].filter(Boolean):soloTop; %>
      <% podOrder.forEach((p,idx) => { const rank=[2,1,3][idx]; %>
      <div class="pod-wrap pod-<%=rank%>">
        <div class="pod-rank"><%=['🥈','🥇','🥉'][idx]%></div>
        <div class="pod-avatar" style="background:<%=p.avatar_color||'#7c3aed'%>"><%=p.username[0].toUpperCase()%></div>
        <div class="pod-name"><%=p.username%></div>
        <div class="pod-wpm"><%=Math.round(p.best_wpm)%> wpm</div>
        <div class="pod-bar">#<%=rank%></div>
      </div>
      <% }) %>
    </div>
    <% } %>
    <div class="lb-card">
      <% if(soloTop && soloTop.length > 0) { %>
      <table>
        <thead><tr><th>#</th><th>Player</th><th>Best WPM</th><th>Avg WPM</th><th>Accuracy</th><th>Tests</th></tr></thead>
        <tbody>
        <% soloTop.forEach((p,i) => { %>
        <tr>
          <td><span class="rank-num" style="color:<%=i===0?'var(--amber)':i===1?'#94a3b8':i===2?'#b45309':'var(--muted)'%>"><%=i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1)%></span></td>
          <td><div class="player-cell"><div class="p-av" style="background:<%=p.avatar_color||'#7c3aed'%>"><%=p.username[0].toUpperCase()%></div><span><%=p.username%></span><%if(p.username===user.username){%><span class="me-tag">you</span><%}%></div></td>
          <td class="td-wpm"><%=Math.round(p.best_wpm)%></td>
          <td style="font-family:var(--mono);color:var(--text2)"><%=Math.round(p.avg_wpm)%></td>
          <td class="td-acc"><%=Math.round(p.avg_acc)%>%</td>
          <td style="color:var(--muted)"><%=p.tests%></td>
        </tr>
        <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty"><i class="fa-regular fa-keyboard"></i><div>No solo data yet. Be the first!</div></div>
      <% } %>
    </div>
  </div>

  <!-- RACE LEADERBOARD -->
  <div class="section" id="tab-multi">
    <% if(multiTop && multiTop.length >= 3) { %>
    <div class="podium-section">
      <% const mPodOrder = multiTop.length>=2?[multiTop[1],multiTop[0],multiTop[2]||null].filter(Boolean):multiTop; %>
      <% mPodOrder.forEach((p,idx) => { const rank=[2,1,3][idx]; %>
      <div class="pod-wrap pod-<%=rank%>">
        <div class="pod-rank"><%=['🥈','🥇','🥉'][idx]%></div>
        <div class="pod-avatar" style="background:<%=p.avatar_color||'#7c3aed'%>"><%=p.username[0].toUpperCase()%></div>
        <div class="pod-name"><%=p.username%></div>
        <div class="pod-wpm"><%=p.wins%> wins</div>
        <div class="pod-bar">#<%=rank%></div>
      </div>
      <% }) %>
    </div>
    <% } %>
    <div class="lb-card">
      <% if(multiTop && multiTop.length > 0) { %>
      <table>
        <thead><tr><th>#</th><th>Player</th><th>Wins</th><th>Races</th><th>Best WPM</th><th>Avg WPM</th></tr></thead>
        <tbody>
        <% multiTop.forEach((p,i) => { %>
        <tr>
          <td><span class="rank-num" style="color:<%=i===0?'var(--amber)':i===1?'#94a3b8':i===2?'#b45309':'var(--muted)'%>"><%=i===0?'🥇':i===1?'🥈':i===2?'🥉':'#'+(i+1)%></span></td>
          <td><div class="player-cell"><div class="p-av" style="background:<%=p.avatar_color||'#7c3aed'%>"><%=p.username[0].toUpperCase()%></div><span><%=p.username%></span><%if(p.username===user.username){%><span class="me-tag">you</span><%}%></div></td>
          <td class="td-wins"><%=p.wins%></td>
          <td style="color:var(--muted)"><%=p.races%></td>
          <td class="td-wpm"><%=Math.round(p.best_wpm)%></td>
          <td style="font-family:var(--mono);color:var(--text2)"><%=Math.round(p.avg_wpm)%></td>
        </tr>
        <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="empty"><i class="fa-solid fa-users"></i><div>No race data yet. Start a race!</div></div>
      <% } %>
    </div>
  </div>
</div>
<script>
function switchTab(tab,btn){
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('show'));
  document.getElementById('tab-'+tab).classList.add('show');
}
</script>
</body>
</html>
